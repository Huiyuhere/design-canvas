name: CI

on:
  push:
    branches: [main]
  pull_request:

jobs:
  checks:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: pnpm/action-setup@v4
        with:
          version: 10
      - uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: pnpm
      - run: pnpm install --frozen-lockfile
      - name: Typecheck
        run: pnpm check
      - name: File-size rule (600 lines)
        run: pnpm check:size
      - name: Inventory / mounts audit
        run: pnpm audit:coverage
      - name: Tests
        run: pnpm test

