{
  "name": "design-canvas",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Code-native design review canvas — render your real app screens on an infinite canvas, edit them visually, and export agent-ready change logs that AI coding agents apply back to source.",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "check:size": "node scripts/check-file-size.mjs",
    "audit:coverage": "tsx scripts/audit-coverage.ts",
    "swift:export": "tsx scripts/swift-export.ts",
    "swift:parity": "tsx scripts/swift-parity.ts",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.2",
    "@trpc/client": "^11.6.0",
    "@trpc/react-query": "^11.6.0",
    "@trpc/server": "^11.6.0",
    "express": "^4.21.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sonner": "^2.0.7",
    "superjson": "^1.13.3",
    "wouter": "^3.3.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@builder.io/vite-plugin-jsx-loc": "^0.1.1",
    "@types/express": "4.17.21",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.25.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.6.2",
    "tsx": "^4.19.1",
    "typescript": "5.9.3",
    "vite": "^7.1.7",
    "vitest": "^2.1.4"
  }
}
